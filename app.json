{
  "expo": {
    "name": "Habita",
    "slug": "habita-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habita.app"
    },
    "android": {
      "package": "com.habita.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      "expo-image-picker",
      "expo-file-system",
      "expo-notifications",
      ["expo-camera", { "recordAudio": false }]
    ],
    "scheme": "habita",
    "experiments": {
      "typedRoutes": true
    }
  }
}
